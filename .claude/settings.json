{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-innerhtml.sh",
            "timeout": 10,
            "statusMessage": "Checking for innerHTML writes..."
          }
        ]
      }
    ]
  }
}
